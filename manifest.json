{
  "manifest_version": 3,
  "name": "ClickOff Field Manager",
  "version": "0.1.0",
  "description": "Tabbed task views and conditional field visibility for ClickUp. Group fields into named tabs — only selected fields are shown.",
  "permissions": ["storage", "sidePanel"],
  "side_panel": { "default_path": "options/options.html" },
  "host_permissions": [
    "https://app.clickup.com/*",
    "https://api.clickup.com/*",
    "https://clickoffext.netlify.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.clickup.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
